# ==========================================================
# AI Medical Report Explainer — Environment Variables
# Copy this file's values into your own `.env` and fill in secrets.
# NEVER commit a real .env file with actual keys to version control.
# ==========================================================

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
GEMINI_MODEL=gemini-1.5-flash

# JWT settings
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./medical_reports.db

# Upload limits
MAX_UPLOAD_MB=20
